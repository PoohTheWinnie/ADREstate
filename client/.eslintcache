":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"88","messages":"89","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"90","messages":"91","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"92"},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"95"},{"filePath":"96","messages":"97","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"98","messages":"99","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"100"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"103","messages":"104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"105","messages":"106","errorCount":0,"warningCount":8,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reportWebVitals.js",[],["107","108"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/NavBar.js",["109"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/errorReducer.js",["110"],"import { GET_ERRORS, CLEAR_ERRORS } from '../actions/types';\n\nconst initialState = {\n    msg: {},\n    status: null,\n    id: null\n}\n\nexport default function(state = initialState, action) {\n    switch(action.type) {\n        case GET_ERRORS:\n            return {\n                msg: action.payload.msg,\n                status: action.payload.status,\n                id: action.payload.id\n            };\n            case CLEAR_ERRORS:\n                return {\n                    msg: {},\n                    status: null,\n                    id: null\n                };\n                default:\n                    return state;\n    }\n}","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/Map.js",["111","112","113","114","115","116","117","118"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/errorActions.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/houseActions.js",["119","120","121","122","123","124","125","126","127"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/SignUp.js",["128","129","130","131","132","133"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/itemReducer.js",["134"],"import {GET_ITEMS, ADD_ITEM, DELETE_ITEM, ITEMS_LOADING} from '../actions/types';\n\nconst initialState = {\n    items: [],\n    loading: false\n}\n\nexport default function(state = initialState, action) {\n    switch(action.type) {\n        case GET_ITEMS:\n            return{\n                ...state,\n                items: action.payload,\n                loading: false\n            };\n        case DELETE_ITEM:\n            return{\n                ...state,\n                items: state.items.filter(item => item._id !== action.payload)\n            };\n        case ADD_ITEM:\n            return{\n                ...state,\n                items: [action.payload, ...state.items]\n            };\n        case ITEMS_LOADING:\n            return{\n                ...state,\n                loading: true\n            }\n            default:\n                return state;\n    }\n}","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/App.js",["135"],"import React, { Component } from \"react\";\nimport { Provider } from 'react-redux';\nimport { BrowserRouter, Route, Switch } from 'react-router-dom';\nimport store from './store';\n\nimport { loadUser } from \"./actions/authActions\";\nimport ProductRegistration from \"./pages/productRegistration\";\nimport Home from \"./pages/home\";\nimport Map from \"./pages/map\";\nimport Profile from \"./pages/profile\";\n\nimport './App.css';\nimport 'bootstrap/dist/css/bootstrap.min.css';\n\n\nclass App extends Component{\n  // componentDidMount(){\n  //   store.dispatch(loadUser());\n  // }\n  render(){\n    return(\n      <Provider store={store}>\n        <BrowserRouter>\n          <Switch>\n            <Route exact path=\"/\">\n                <Home/>\n            </Route>\n            <Route exact path=\"/Map\">\n                <Map/>\n            </Route>\n            <Route exact path=\"/Profile/:userId\">\n                <Profile/>\n            </Route>\n            <Route exact path=\"/Product\">\n              <ProductRegistration/>\n            </Route>\n          </Switch>\n        </BrowserRouter>\n      </Provider>\n    );\n  }\n}\n\n\nexport default App;","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/index.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/productRegistration.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/home.js",["136","137","138","139","140","141","142","143","144"],"import React, { Component } from 'react';\nimport {\n    Row,\n    Col,\n    Button,\n    CardText,\n} from 'reactstrap';\nimport Image from 'react-bootstrap/Image';\nimport ReactCardFlip from 'react-card-flip';\nimport PropTypes from 'prop-types';\nimport { connect } from 'react-redux';\nimport { Fade } from \"react-slideshow-image\";\nimport { Icon } from '@iconify/react';\nimport lawIcon from '@iconify-icons/whh/law';\nimport mapIcon from '@iconify-icons/carbon/map'\nimport 'react-slideshow-image/dist/styles.css';\n\nimport NewYork from \"../Images/New York.png\";\nimport Boston from \"../Images/Boston.png\";\nimport LosAngeles from \"../Images/Los Angeles.png\";\nimport London from \"../Images/London.png\";\nimport MapSmall from \"../Images/MapSmall.png\";\nimport NavBar from '../components/navBar';\nimport Footer from '../components/footer';\nimport LoginModal from \"../components/loginModal\";\n\n\nclass Home extends Component{\n    static propTypes = {\n        auth: PropTypes.object.isRequired\n    }\n    render(){\n        const { isAuthenticated, user } = this.props.auth;\n        const cities = [\n            \"New York\",\n            \"Boston\",\n            \"Miami\",\n            \"Los Angeles\"\n        ];\n        const info = (\n            <div>\n                <div className=\"SectionCities\">\n                    <div className=\"Cities\">\n                        <h2>Available in major cities</h2>\n                        <Col md=\"4\" className=\"ListCities\">\n                            {cities.map((city) =>\n                                <h4 className=\"City\" color=\"primary\" block><strong>{city}</strong></h4>\n                            )}\n                        </Col>\n                    </div>\n                </div>\n                <div className=\"SectionFeatures\">\n                    <div className=\"Features\">\n                        <h2 className=\"FeaturesLabel\">Features</h2>\n                        <br/>\n                        <div className=\"ListFeatures\">\n                            <div className=\"Item\">\n                                <Icon icon={lawIcon} className=\"FeatureIcon\"/>\n                                <h4 className=\"UserTypeText\">Easily challenge your home appraisal</h4>\n                            </div>\n                            <div>\n                                <Icon icon={mapIcon} className=\"FeatureIcon\"/>\n                                <h4 className=\"UserTypeText\">Check and compare the value of other homes</h4>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        );\n        const authLinks = (\n            <div className=\"slide-container\">\n                <Fade>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={NewYork} />\n                    </div>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={Boston} />\n                    </div>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={LosAngeles} />\n                    </div>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={London} />\n                    </div>\n                </Fade>\n            </div>\n        );\n        const guestLinks = (\n            <div>\n                <div className=\"SectionSignLog\">\n                    <div className=\"SignLog\">\n                        <div>\n                            <Image className=\"ImageSign\" src= {MapSmall} roundedCircle/>\n                        </div>\n                        <LoginModal/>\n                    </div>\n                </div>\n            </div>\n        );\n\n        return(\n            <div>\n                <NavBar/>\n                    { isAuthenticated ? authLinks : guestLinks }\n                    {info}\n                <Footer/>\n            </div>\n        );\n    }\n}\n\nconst mapStateToProps = state => ({\n    auth: state.auth\n});\n\nexport default connect(mapStateToProps, null)(Home);\n","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/login.js",[],["145","146"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/signup.js",["147","148","149","150","151","152"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/profile.js",["153","154","155","156","157","158"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/types.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/navBar.js",["159"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/authReducer.js",["160"],"import {\n    USER_LOADED,\n    USER_LOADING,\n    AUTH_ERROR,\n    LOGIN_SUCCESS,\n    LOGIN_FAIL,\n    LOGOUT_SUCCESS,\n    REGISTER_SUCCESS,\n    REGISTER_FAIL,\n    // EMP_REGISTER_SUCCESS,\n} from '../actions/types';\n\nconst initialState = {\n    token: localStorage.getItem('token'),\n    isAuthenticated: null,\n    isLoading: true,\n    user: null\n};\n\nexport default function(state = initialState, action) {\n    switch(action.type) {\n        case USER_LOADING:\n            return {\n                ...state,\n                isLoading: true\n            };\n        case USER_LOADED:\n            return {\n                ...state,\n                isAuthenticated: true,\n                isLoading: false,\n                user: action.payload\n            };\n        case LOGIN_SUCCESS:\n            console.log(\"login success\");\n            console.log(action.payload);\n            return {\n                ...state,\n                ...action.payload,\n                isAuthenticated: true,\n                user: action.payload,\n            };\n        case REGISTER_SUCCESS:\n            localStorage.setItem('token', action.payload.token);\n            return {\n                ...state,\n                ...action.payload,\n                isAuthenticated: true,\n                isLoading: false,\n                user: action.payload\n            };\n        \n        case AUTH_ERROR:\n        case LOGIN_FAIL:\n        case LOGOUT_SUCCESS:\n        case REGISTER_FAIL:\n            localStorage.removeItem('token');\n            return {\n                ...state,\n                token: null,\n                user: null,\n                isAuthenticated: false,\n                isLoading: false\n            };\n        default:\n            return state;\n    }\n}","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/index.js",[],["161","162"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/authActions.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/store.js",[],["163","164"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/productActions.js",["165"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/loginModal.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/map.js",["166","167","168","169","170","171","172","173"],{"ruleId":"174","replacedBy":"175"},{"ruleId":"176","replacedBy":"177"},{"ruleId":"178","severity":1,"message":"179","line":10,"column":5,"nodeType":"180","messageId":"181","endLine":10,"endColumn":14},{"ruleId":"182","severity":1,"message":"183","line":9,"column":1,"nodeType":"184","endLine":26,"endColumn":2},{"ruleId":"178","severity":1,"message":"185","line":17,"column":5,"nodeType":"180","messageId":"181","endLine":17,"endColumn":12},{"ruleId":"178","severity":1,"message":"186","line":18,"column":5,"nodeType":"180","messageId":"181","endLine":18,"endColumn":10},{"ruleId":"178","severity":1,"message":"187","line":19,"column":5,"nodeType":"180","messageId":"181","endLine":19,"endColumn":17},{"ruleId":"178","severity":1,"message":"188","line":20,"column":5,"nodeType":"180","messageId":"181","endLine":20,"endColumn":13},{"ruleId":"178","severity":1,"message":"189","line":21,"column":5,"nodeType":"180","messageId":"181","endLine":21,"endColumn":13},{"ruleId":"178","severity":1,"message":"190","line":22,"column":5,"nodeType":"180","messageId":"181","endLine":22,"endColumn":13},{"ruleId":"178","severity":1,"message":"191","line":142,"column":15,"nodeType":"180","messageId":"181","endLine":142,"endColumn":27},{"ruleId":"178","severity":1,"message":"192","line":146,"column":15,"nodeType":"180","messageId":"181","endLine":146,"endColumn":27},{"ruleId":"178","severity":1,"message":"193"