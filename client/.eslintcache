:0,"fixableWarningCount":0},{"filePath":"89","messages":"90","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"91"},"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reportWebVitals.js",[],["92","93"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/NavBar.js",["94"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/errorReducer.js",["95"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/Map.js",["96","97","98","99","100","101","102","103"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/errorActions.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/houseActions.js",["104","105","106","107","108","109","110","111","112"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/SignUp.js",["113","114","115","116","117","118"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/itemReducer.js",["119"],"import {GET_ITEMS, ADD_ITEM, DELETE_ITEM, ITEMS_LOADING} from '../actions/types';\n\nconst initialState = {\n    items: [],\n    loading: false\n}\n\nexport default function(state = initialState, action) {\n    switch(action.type) {\n        case GET_ITEMS:\n            return{\n                ...state,\n                items: action.payload,\n                loading: false\n            };\n        case DELETE_ITEM:\n            return{\n                ...state,\n                items: state.items.filter(item => item._id !== action.payload)\n            };\n        case ADD_ITEM:\n            return{\n                ...state,\n                items: [action.payload, ...state.items]\n            };\n        case ITEMS_LOADING:\n            return{\n                ...state,\n                loading: true\n            }\n            default:\n                return state;\n    }\n}","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/App.js",["120"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/index.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/productRegistration.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/home.js",["121","122","123","124","125","126","127","128","129"],"import React, { Component } from 'react';\nimport {\n    Row,\n    Col,\n    Button,\n    CardText,\n} from 'reactstrap';\nimport Image from 'react-bootstrap/Image';\nimport ReactCardFlip from 'react-card-flip';\nimport PropTypes from 'prop-types';\nimport { connect } from 'react-redux';\nimport { Fade } from \"react-slideshow-image\";\nimport { Icon } from '@iconify/react';\nimport lawIcon from '@iconify-icons/whh/law';\nimport mapIcon from '@iconify-icons/carbon/map'\nimport 'react-slideshow-image/dist/styles.css';\n\nimport NewYork from \"../Images/New York.png\";\nimport Boston from \"../Images/Boston.png\";\nimport LosAngeles from \"../Images/Los Angeles.png\";\nimport London from \"../Images/London.png\";\nimport MapSmall from \"../Images/MapSmall.png\";\nimport NavBar from '../components/navBar';\nimport Footer from '../components/footer';\nimport LoginModal from \"../components/loginModal\";\n\n\nclass Home extends Component{\n    static propTypes = {\n        auth: PropTypes.object.isRequired\n    }\n    render(){\n        const { isAuthenticated, user } = this.props.auth;\n        const cities = [\n            \"New York\",\n            \"Boston\",\n            \"Miami\",\n            \"Los Angeles\"\n        ];\n        const info = (\n            <div>\n                <div className=\"SectionCities\">\n                    <div className=\"Cities\">\n                        <h2>Available in major cities</h2>\n                        <Col md=\"4\" className=\"ListCities\">\n                            {cities.map((city) =>\n                                <h4 className=\"City\" color=\"primary\" block><strong>{city}</strong></h4>\n                            )}\n                        </Col>\n                    </div>\n                </div>\n                <div className=\"SectionFeatures\">\n                    <div className=\"Features\">\n                        <h2 className=\"FeaturesLabel\">Features</h2>\n                        <br/>\n                        <div className=\"ListFeatures\">\n                            <div className=\"Item\">\n                                <Icon icon={lawIcon} className=\"FeatureIcon\"/>\n                                <h4 className=\"UserTypeText\">Easily challenge your home appraisal</h4>\n                            </div>\n                            <div>\n                                <Icon icon={mapIcon} className=\"FeatureIcon\"/>\n                                <h4 className=\"UserTypeText\">Check and compare the value of other homes</h4>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        );\n        const authLinks = (\n            <div className=\"slide-container\">\n                <Fade>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={NewYork} />\n                    </div>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={Boston} />\n                    </div>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={LosAngeles} />\n                    </div>\n                    <div className=\"each-fade\">\n                        <img className=\"Image\" src={London} />\n                    </div>\n                </Fade>\n            </div>\n        );\n        const guestLinks = (\n            <div>\n                <div className=\"SectionSignLog\">\n                    <div className=\"SignLog\">\n                        <div>\n                            <Image className=\"ImageSign\" src= {MapSmall} roundedCircle/>\n                        </div>\n                        <LoginModal/>\n                    </div>\n                </div>\n            </div>\n        );\n\n        return(\n            <div>\n                <NavBar/>\n                    { isAuthenticated ? authLinks : guestLinks }\n                    {info}\n                <Footer/>\n            </div>\n        );\n    }\n}\n\nconst mapStateToProps = state => ({\n    auth: state.auth\n});\n\nexport default connect(mapStateToProps, null)(Home);\n","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/login.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/signup.js",["130","131","132","133","134","135"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/pages/profile.js",["136","137","138","139","140"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/types.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/components/navBar.js",["141"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/reducers/authReducer.js",["142"],"import {\n    USER_LOADED,\n    USER_LOADING,\n    AUTH_ERROR,\n    LOGIN_SUCCESS,\n    LOGIN_FAIL,\n    LOGOUT_SUCCESS,\n    REGISTER_SUCCESS,\n    REGISTER_FAIL,\n    // EMP_REGISTER_SUCCESS,\n} from '../actions/types';\n\nconst initialState = {\n    token: localStorage.getItem('token'),\n    isAuthenticated: null,\n    isLoading: true,\n    user: null\n};\n\nexport default function(state = initialState, action) {\n    switch(action.type) {\n        case USER_LOADING:\n            return {\n                ...state,\n                isLoading: true\n            };\n        case USER_LOADED:\n            return {\n                ...state,\n                isAuthenticated: true,\n                isLoading: false,\n                user: action.payload\n            };\n        case LOGIN_SUCCESS:\n            console.log(\"login success\");\n            console.log(action.payload);\n            return {\n                ...state,\n                ...action.payload,\n                isAuthenticated: true,\n                user: action.payload,\n                \n            };\n        case REGISTER_SUCCESS:\n            localStorage.setItem('token', action.payload.token);\n            return {\n                ...state,\n                ...action.payload,\n                isAuthenticated: true,\n                isLoading: false,\n                user: action.payload\n            };\n        \n        case AUTH_ERROR:\n        case LOGIN_FAIL:\n        case LOGOUT_SUCCESS:\n        case REGISTER_FAIL:\n            localStorage.removeItem('token');\n            return {\n                ...state,\n                token: null,\n                user: null,\n                isAuthenticated: false,\n                isLoading: false\n            };\n        default:\n            return state;\n    }\n}","/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/index.js",[],["143","144"],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/actions/authActions.js",[],"/Users/winston/Documents/Programming/WebDevelopment/ADREstate/client/src/store.js",[],["145","146"],{"ruleId":"147","replacedBy":"148"},{"ruleId":"149","replacedBy":"150"},{"ruleId":"151","severity":1,"message":"152","line":10,"column":5,"nodeType":"153","messageId":"154","endLine":10,"endColumn":14},{"ruleId":"155","severity":1,"message":"156","line":9,"column":1,"nodeType":"157","endLine":26,"endColumn":2},{"ruleId":"151","severity":1,"message":"158","line":17,"column":5,"nodeType":"153","messageId":"154","endLine":17,"endColumn":12},{"ruleId":"151","severity":1,"message":"159","line":18,"column":5,"nodeType":"